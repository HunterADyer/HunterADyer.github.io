{
  "$ref": "#/definitions/projects",
  "definitions": {
    "projects": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "tagline": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "default": ""
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "completed",
            "archived",
            "planned"
          ]
        },
        "githubUrl": {
          "type": "string",
          "format": "uri"
        },
        "image": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "featured": {
          "type": "boolean",
          "default": false
        },
        "sortOrder": {
          "type": "number",
          "default": 0
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "tagline",
        "status"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}