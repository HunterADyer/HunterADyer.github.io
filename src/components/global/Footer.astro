---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner container">
    <p class="footer-text">
      &copy; {year} Hunter A. Dyer
    </p>
    <div class="footer-links">
      <a href="/rss.xml" class="no-typing">RSS</a>
      <a href="https://github.com/HunterADyer" target="_blank" rel="noopener noreferrer" class="no-typing">GitHub</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-xl) 0;
    margin-top: var(--space-3xl);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .footer-text {
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  .footer-links {
    display: flex;
    gap: var(--space-md);
  }

  .footer-links a {
    font-size: 0.85rem;
    color: var(--color-muted);
    transition: color var(--transition-fast);
  }

  .footer-links a:hover {
    color: var(--color-accent);
  }
</style>
