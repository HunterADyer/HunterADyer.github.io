---
interface Props {
  id: string;
  file?: string;
}

const { id, file } = Astro.props;
const src = file
  ? `https://gist.github.com/${id}.js?file=${encodeURIComponent(file)}`
  : `https://gist.github.com/${id}.js`;
---

<div class="gist-embed">
  <script src={src}></script>
</div>

<style>
  .gist-embed {
    margin: var(--space-lg) 0;
  }

  .gist-embed :global(.gist .gist-data) {
    border: 1px solid var(--color-border) !important;
    border-radius: var(--radius-md);
  }

  [data-theme="hacker"] .gist-embed :global(.gist .gist-data) {
    background: var(--color-surface) !important;
  }

  [data-theme="hacker"] .gist-embed :global(.gist .gist-data .blob-code) {
    color: var(--color-text) !important;
  }
</style>
