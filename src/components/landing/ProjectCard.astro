---
interface Props {
  name: string;
  tagline: string;
  description: string;
  tags: string[];
  slug: string;
  status: string;
}

const { name, tagline, description, tags, slug } = Astro.props;
---

<a href={`/projects/${slug.replace(/\.mdx?$/, '')}/`} class="project-card no-typing">
  <h3>{name}</h3>
  <p class="tagline">{tagline}</p>
  <p>{description}</p>
  <div class="tag-list">
    {tags.map((tag) => (
      <span class="tag">{tag}</span>
    ))}
  </div>
</a>
