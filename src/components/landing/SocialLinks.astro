---
const links = [
  { label: 'GitHub', href: 'https://github.com/HunterADyer', icon: '⟨/⟩' },
  { label: 'Email', href: 'mailto:hunter@hunteradyer.com', icon: '@' },
];
---

<div class="social-links">
  {links.map(({ label, href, icon }) => (
    <a href={href} class="social-link no-typing" target="_blank" rel="noopener noreferrer">
      <span class="social-icon">{icon}</span>
      {label}
    </a>
  ))}
</div>
