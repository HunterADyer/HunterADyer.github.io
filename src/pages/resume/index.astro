---
import LandingLayout from '../../layouts/LandingLayout.astro';
import ViewToggle from '../../components/resume/ViewToggle.astro';
import TraditionalResume from '../../components/resume/TraditionalResume.astro';
import Timeline from '../../components/resume/Timeline';
import { getEntry } from 'astro:content';

const experience = await getEntry('resume', 'experience');
const education = await getEntry('resume', 'education');
const publications = await getEntry('resume', 'publications');

// Build timeline items from resume data
const timelineItems = [
  ...experience.data.items.map((item: any) => ({
    title: item.title,
    subtitle: `${item.company} — ${item.location}`,
    date: `${item.startDate} – ${item.endDate}`,
    description: item.description,
    highlights: item.highlights || [],
    type: 'experience' as const,
  })),
  ...education.data.items.map((item: any) => ({
    title: item.degree,
    subtitle: `${item.institution} — ${item.location}`,
    date: `${item.startDate} – ${item.endDate}`,
    description: item.description,
    highlights: item.highlights || [],
    type: 'education' as const,
  })),
  ...publications.data.items.map((item: any) => ({
    title: item.title,
    subtitle: `${item.venue} (${item.year})`,
    date: String(item.year),
    description: item.description,
    highlights: [],
    type: 'publication' as const,
  })),
];
---

<LandingLayout title="Resume" description="Hunter A. Dyer's professional resume">
  <div class="resume-page">
    <h1 class="section-title">Resume</h1>
    <ViewToggle />

    <div id="timeline-view">
      <Timeline client:visible items={timelineItems} />
    </div>

    <div id="traditional-view" style="display: none;">
      <TraditionalResume />
    </div>
  </div>
</LandingLayout>

<style>
  .resume-page {
    padding: var(--space-xl) 0;
  }

  .section-title {
    text-align: center;
    margin-bottom: var(--space-xl);
  }
</style>
