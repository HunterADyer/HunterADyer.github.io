---
import LandingLayout from '../../../layouts/LandingLayout.astro';
import PostList from '../../../components/blog/PostList.astro';
import CategoryTabs from '../../../components/blog/CategoryTabs.astro';
import { getCollection } from 'astro:content';
import { getUniqueTags } from '../../../lib/utils';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft && !data.unlisted);
  const tags = getUniqueTags(posts);

  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts.filter((p) => p.data.tags.includes(tag)),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<LandingLayout title={`Tag: ${tag}`} description={`Posts tagged with "${tag}"`}>
  <div class="blog-page">
    <h1 class="section-title">#{tag}</h1>
    <CategoryTabs />
    <PostList posts={posts} />
  </div>
</LandingLayout>

<style>
  .blog-page {
    padding: var(--space-xl) 0;
  }
</style>
