---
import HackerLayout from '../../layouts/HackerLayout.astro';
import CategoryTabs from '../../components/blog/CategoryTabs.astro';
import PostList from '../../components/blog/PostList.astro';
import TagCloud from '../../components/blog/TagCloud.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft && !data.unlisted);
---

<HackerLayout title="Blog" description="Security research, reverse engineering, and random thoughts.">
  <div class="blog-page">
    <h1 class="section-title">Blog</h1>
    <CategoryTabs current="all" />
    <TagCloud posts={posts} />
    <PostList posts={posts} />
  </div>
</HackerLayout>

<style>
  .blog-page {
    padding: var(--space-xl) 0;
  }
</style>
