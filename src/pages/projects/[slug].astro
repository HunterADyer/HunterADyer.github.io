---
import LandingLayout from '../../layouts/LandingLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id.replace(/\.mdx?$/, '') },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
---

<LandingLayout title={project.data.name} description={project.data.description}>
  <article class="project-detail">
    <header class="project-header">
      <div class="project-meta">
        <span class:list={['status-badge', project.data.status]}>
          {project.data.status}
        </span>
        {project.data.githubUrl && (
          <a href={project.data.githubUrl} class="github-link no-typing" target="_blank" rel="noopener noreferrer">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
            </svg>
            Source
          </a>
        )}
      </div>
      <h1>{project.data.name}</h1>
      <p class="tagline">{project.data.tagline}</p>
      <div class="tag-list">
        {project.data.tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    </header>

    <div class="prose">
      <Content />
    </div>

    <footer class="project-footer">
      <a href="/projects/">&larr; All Projects</a>
    </footer>
  </article>
</LandingLayout>

<style>
  .project-detail {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: var(--space-xl) 0;
  }

  .project-header {
    margin-bottom: var(--space-xl);
  }

  .project-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .github-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: 0.85rem;
    color: var(--color-muted);
    transition: color var(--transition-fast);
  }

  .github-link:hover {
    color: var(--color-accent);
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: var(--space-sm);
  }

  .tagline {
    font-size: 1.1rem;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .prose {
    line-height: 1.8;
    font-size: 0.95rem;
  }

  .prose :global(h2) {
    font-size: 1.5rem;
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
    color: var(--color-heading);
  }

  .prose :global(h3) {
    font-size: 1.2rem;
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
    color: var(--color-heading);
  }

  .prose :global(p) {
    margin-bottom: var(--space-md);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: var(--space-md);
    padding-left: var(--space-xl);
  }

  .prose :global(ul) { list-style: disc; }
  .prose :global(ol) { list-style: decimal; }

  .prose :global(li) {
    margin-bottom: var(--space-xs);
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-lg) 0;
    font-size: 0.875rem;
  }

  .prose :global(th),
  .prose :global(td) {
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--color-border);
    text-align: left;
  }

  .prose :global(th) {
    background: var(--color-surface);
    font-weight: 600;
    color: var(--color-heading);
  }

  .prose :global(strong) {
    color: var(--color-heading);
  }

  .project-footer {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .project-footer a {
    font-size: 0.9rem;
    color: var(--color-accent);
  }
</style>
