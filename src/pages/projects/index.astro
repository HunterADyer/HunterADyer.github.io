---
import LandingLayout from '../../layouts/LandingLayout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const sorted = projects.sort((a, b) => a.data.sortOrder - b.data.sortOrder);
---

<LandingLayout title="Projects" description="Security research and software projects by Hunter A. Dyer">
  <div class="projects-page">
    <h1 class="section-title">Projects</h1>
    <div class="project-grid">
      {sorted.map((project) => (
        <a href={`/projects/${project.id.replace(/\.mdx?$/, '')}/`} class="project-card no-typing">
          <div class="project-card-header">
            <h3>{project.data.name}</h3>
            <span class:list={['status-badge', project.data.status]}>
              {project.data.status}
            </span>
          </div>
          <p class="tagline">{project.data.tagline}</p>
          <p>{project.data.description}</p>
          <div class="tag-list">
            {project.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
          <span class="project-link">Read writeup &rarr;</span>
        </a>
      ))}
    </div>
  </div>
</LandingLayout>

<style>
  .projects-page {
    padding: var(--space-xl) 0;
  }

  .project-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }

  .project-link {
    display: inline-block;
    margin-top: var(--space-md);
    font-size: 0.85rem;
    color: var(--color-accent);
  }
</style>
